---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Impressum — Vits Consulting" noindex>
  <div class="wrap">
    <a href="/" class="back"><span class="arrow" aria-hidden="true">&larr;</span> Vits Consulting</a>
  </div>
  <hr class="rule" />
  <main>
    <div class="wrap">
      <h1>Impressum</h1>
      <p class="doc-meta">Angaben gemäß § 5 TMG</p>

      <div class="block">
        <h2>Anbieter</h2>
        <p>
          <span class="name">Vits Consulting UG (haftungsbeschränkt)</span><br />
          Meisenstrasse 6<br />
          40789 Monheim am Rhein<br />
          Germany
        </p>
      </div>

      <div class="block">
        <h2>Vertreten durch</h2>
        <p>Thomas Vits (Geschäftsführer)</p>
      </div>

      <div class="block">
        <h2>Kontakt</h2>
        <p>Email: <a href="mailto:thomas@vits-consulting.de">thomas@vits-consulting.de</a></p>
      </div>

      <div class="block">
        <h2>Registereintrag</h2>
        <p>
          Handelsregister: HRB 90410<br />
          Registergericht: Amtsgericht Düsseldorf
        </p>
      </div>

      <div class="block">
        <h2>Umsatzsteuer-ID</h2>
        <p>USt-IdNr.: DE333840324</p>
      </div>

      <div class="block">
        <h2>Verantwortlich für den Inhalt nach § 55 Abs. 2 RStV</h2>
        <p>
          <span class="name">Thomas Vits</span><br />
          Meisenstrasse 6<br />
          40789 Monheim am Rhein
        </p>
      </div>
    </div>
  </main>
  <div class="wrap">
    <footer>
      <span>Vits Consulting UG (haftungsbeschränkt)</span>
      <span><a href="/">Home</a> &middot; <a href="/privacy">Privacy Policy</a></span>
    </footer>
  </div>
</BaseLayout>

<style>
  .back {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--mono);
    font-size: 0.8rem;
    color: var(--muted);
    padding-block: 1.6rem;
  }
  .back:hover { color: var(--ink); }
  .back .arrow { transition: transform 0.18s ease; }
  .back:hover .arrow { transform: translateX(-3px); }

  main { padding-block: clamp(3rem, 8vw, 5rem) clamp(4rem, 10vw, 6rem); }

  h1 {
    font-size: clamp(1.9rem, 5vw, 2.5rem);
    font-weight: 600;
    letter-spacing: -0.025em;
    margin: 0 0 0.4rem;
  }

  .doc-meta {
    font-family: var(--mono);
    font-size: 0.78rem;
    color: var(--faint);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    margin: 0 0 3rem;
  }

  .block { margin-bottom: 2.4rem; }
  .block h2 {
    font-family: var(--mono);
    font-size: 0.78rem;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--accent);
    margin: 0 0 0.7rem;
  }
  .block p {
    margin: 0;
    color: var(--muted);
    line-height: 1.7;
  }
  .block p .name { color: var(--ink); font-weight: 500; }

  footer {
    border-top: 1px solid var(--line);
    padding-block: 2.5rem;
    font-family: var(--mono);
    font-size: 0.8rem;
    color: var(--muted);
    display: flex;
    flex-wrap: wrap;
    gap: 1.4rem;
    justify-content: space-between;
  }
  footer a { color: var(--muted); }
  footer a:hover { color: var(--ink); }
</style>
